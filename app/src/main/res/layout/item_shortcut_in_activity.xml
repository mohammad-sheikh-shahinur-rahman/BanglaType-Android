<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/shortcut_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/tiny_margin"
    android:padding="@dimen/activity_margin">

    <com.itamadersomajinc.banglatype.commons.views.MyTextView
        android:id="@+id/shortcut_trigger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="@dimen/normal_text_size"
        android:textStyle="bold"
        tools:text="btw" />

    <com.itamadersomajinc.banglatype.commons.views.MyTextView
        android:id="@+id/shortcut_expansion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/shortcut_trigger"
        android:layout_marginTop="@dimen/tiny_margin"
        android:alpha="0.8"
        android:ellipsize="end"
        android:maxLines="5"
        android:textSize="@dimen/normal_text_size"
        tools:text="by the way" />

</RelativeLayout>
