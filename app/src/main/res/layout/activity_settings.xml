<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background">

    <com.itamadersomajinc.banglatype.commons.views.MyAppBarLayout
        android:id="@+id/settings_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/settings_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings"
            app:titleTextAppearance="@style/AppTheme.ActionBar.TitleTextStyle" />

    </com.itamadersomajinc.banglatype.commons.views.MyAppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/settings_nested_scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/brand_background"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/settings_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- Header Illustration Area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="-60dp"
                android:background="@drawable/splash_background">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/black"
                    android:alpha="0.2" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/logo_banglatype"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="@android:color/white"
                        app:strokeWidth="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="BanglaType Keyboard"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- Section: Appearance -->
            <TextView
                android:id="@+id/settings_color_customization_section_label"
                style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.05"
                android:text="@string/color_customization"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/settings_color_customization_holder"
                        style="@style/SettingsHolderTextViewOneLinerStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <ImageView
                            android:id="@+id/settings_color_customization_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_feature_updates"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/brand_blue" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_color_customization_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/customize_colors"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/settings_color_customization_icon"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/settings_keyboard_theme_holder"
                        style="@style/SettingsHolderTextViewStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <ImageView
                            android:id="@+id/settings_keyboard_theme_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_feature_layout"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/brand_blue" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_keyboard_theme_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/keyboard_theme"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/settings_keyboard_theme_icon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_keyboard_theme_value"
                            style="@style/SettingsTextValueStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            app:layout_constraintStart_toStartOf="@id/settings_keyboard_theme_label"
                            app:layout_constraintTop_toBottomOf="@+id/settings_keyboard_theme_label"
                            tools:text="@string/theme_default" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/settings_font_holder"
                        style="@style/SettingsHolderTextViewStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <ImageView
                            android:id="@+id/settings_font_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_text_editing_vector"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/brand_blue" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_font_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/font"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/settings_font_icon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_font_value"
                            style="@style/SettingsTextValueStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            app:layout_constraintStart_toStartOf="@id/settings_font_label"
                            app:layout_constraintTop_toBottomOf="@+id/settings_font_label"
                            tools:text="Default" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:id="@+id/settings_use_system_colors_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_use_system_colors_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_use_system_colors"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/use_system_colors"
                            android:textStyle="bold" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: General -->
            <TextView
                android:id="@+id/settings_general_settings_label"
                style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.05"
                android:text="@string/general_settings"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/settings_language_holder"
                        style="@style/SettingsHolderTextViewStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_language_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/language"
                            android:textStyle="bold" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_language"
                            style="@style/SettingsTextValueStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/settings_language_label"
                            android:layout_marginTop="2dp" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_use_english_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_use_english"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/use_english_language"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_keyboard_language_holder"
                        style="@style/SettingsHolderTextViewStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_keyboard_language_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/keyboard_language"
                            android:textStyle="bold" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_keyboard_language"
                            style="@style/SettingsTextValueStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/settings_keyboard_language_label"
                            android:layout_marginTop="2dp"
                            tools:text="@string/translation_english" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_manage_keyboard_languages_holder"
                        style="@style/SettingsHolderTextViewOneLinerStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_manage_keyboard_languages"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/manage_keyboard_languages"
                            android:textStyle="bold" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Layout -->
            <TextView
                android:id="@+id/settings_layout_appearance_label"
                style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.05"
                android:text="@string/layout_and_appearance"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/settings_show_key_borders_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_show_key_borders"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/show_key_borders"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_show_numbers_row_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_show_numbers_row"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/show_numbers_row"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_auto_punctuation_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_auto_punctuation"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_punctuation"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_keyboard_height_multiplier_holder"
                        style="@style/SettingsHolderTextViewStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_keyboard_height_multiplier_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/keyboard_height"
                            android:textStyle="bold" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_keyboard_height_multiplier"
                            style="@style/SettingsTextValueStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/settings_keyboard_height_multiplier_label"
                            android:layout_marginTop="2dp"
                            tools:text="100%" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Keypress -->
            <TextView
                android:id="@+id/settings_keypress_label"
                style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.05"
                android:text="@string/keypress"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/settings_show_popup_on_keypress_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_show_popup_on_keypress"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/show_popup"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_vibrate_on_keypress_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_vibrate_on_keypress"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/vibrate_on_keypress"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_sound_on_keypress_holder"
                        style="@style/SettingsHolderTextViewStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_sound_on_keypress_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sound_on_keypress"
                            android:textStyle="bold" />

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_sound_on_keypress"
                            style="@style/SettingsTextValueStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/settings_sound_on_keypress_label"
                            android:layout_marginTop="2dp" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Voice Typing -->
            <TextView
                android:id="@+id/settings_typing_input_label"
                style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.05"
                android:text="@string/voice_typing"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/settings_continuous_voice_typing_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_continuous_voice_typing"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/continuous_voice_typing"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_voice_typing_punctuation_holder"
                        style="@style/SettingsHolderSwitchStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyMaterialSwitch
                            android:id="@+id/settings_voice_typing_punctuation"
                            style="@style/SettingsSwitchStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_typing_punctuation"
                            android:textStyle="bold" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Support -->
            <TextView
                android:id="@+id/settings_support_label"
                style="@style/SettingsSectionLabelStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.05"
                android:text="সাহায্য ও তথ্য (Support)"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/settings_manual_holder"
                        style="@style/SettingsHolderTextViewOneLinerStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_manual_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ব্যবহার বিধি (User Manual)"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_privacy_policy_holder"
                        style="@style/SettingsHolderTextViewOneLinerStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_privacy_policy_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/privacy_policy"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="#0D000000" />

                    <RelativeLayout
                        android:id="@+id/settings_about_holder"
                        style="@style/SettingsHolderTextViewOneLinerStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_background"
                        android:padding="20dp">

                        <com.itamadersomajinc.banglatype.commons.views.MyTextView
                            android:id="@+id/settings_about_label"
                            style="@style/SettingsTextLabelStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/about"
                            android:textStyle="bold" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:alpha="0.4"
                android:text="BanglaType v1.0.0"
                android:textColor="@color/brand_navy_text"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
