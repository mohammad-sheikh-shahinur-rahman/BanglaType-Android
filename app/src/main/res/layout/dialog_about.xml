<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/about_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/app_launcher_name"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@drawable/logo_banglatype"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/brand_blue"
            app:strokeWidth="3dp" />

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:id="@+id/about_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/app_name"
            android:textColor="@color/brand_navy_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:id="@+id/about_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/writing_be_vivid"
            android:textColor="@color/brand_blue"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:textStyle="bold" />

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:id="@+id/about_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1A0078F8"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="@color/brand_blue"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginVertical="32dp"
            android:background="@color/brand_blue"
            android:alpha="0.3" />

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.6"
            android:text="@string/about_developer_label"
            android:textColor="@color/brand_navy_text"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:id="@+id/about_developer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/about_developer_name"
            android:textColor="@color/brand_navy_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:id="@+id/about_developer_designation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.7"
            android:gravity="center"
            android:text="@string/about_developer_designation"
            android:textColor="@color/brand_navy_text"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/about_linkedin"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/ripple_all_corners_medium"
                android:contentDescription="@string/about_linkedin"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_language_outlined"
                app:tint="@color/brand_blue" />

            <ImageButton
                android:id="@+id/about_facebook"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/ripple_all_corners_medium"
                android:contentDescription="@string/about_facebook"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_feature_updates"
                app:tint="@color/brand_blue" />

            <ImageButton
                android:id="@+id/about_website"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/ripple_all_corners_medium"
                android:contentDescription="@string/about_website"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_language_outlined"
                app:tint="@color/brand_blue" />

            <ImageButton
                android:id="@+id/about_email"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/ripple_all_corners_medium"
                android:contentDescription="@string/about_email"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_text_editing_vector"
                app:tint="@color/brand_blue" />

        </LinearLayout>

        <com.itamadersomajinc.banglatype.commons.views.MyTextView
            android:id="@+id/about_copyright"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:alpha="0.5"
            android:text="@string/about_copyright"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
