    <string name="manual_clipboard_title">ক্লিপবোর্ড ব্যবস্থাপনা</string>
    <string name="manual_clipboard_desc">আপনার কপি করা টেক্সটগুলো এখানে জমা থাকে। আপনি চাইলে প্রিয় ক্লিপগুলো পিন করে রাখতে পারেন যাতে পরে আর হারিয়ে না যায়।</string>
    <string name="manual_shortcuts_title">টেক্সট শর্টকাট</string>
    <string name="manual_shortcuts_desc">ছোট ট্রিগার (যেমন \'omw\') লিখলে তা স্বয়ংক্রিয়ভাবে বড় টেক্সটে (যেমন \'On my way\') পরিবর্তিত হবে।</string>
    <string name="manual_themes_title">থিম ও কাস্টমাইজেশন</string>
    <string name="manual_themes_desc">আপনার কিবোর্ডকে সাজাতে বিভিন্ন থিম ব্যবহার করুন অথবা গ্যালারি থেকে নিজের ছবি ব্যাকগ্রাউন্ড হিসেবে সেট করুন।</string>
    <string name="privacy_title">আপনার ডাটা নিরাপদ</string>
    <string name="privacy_desc">BanglaType কিবোর্ড থেকে আপনার লেখা কোনো কিছু কখনো আপনার ডিভাইসের বাইরে যায় না। শুধু সাজেশন দেখানোর জন্য লেখা থেকে শব্দগুলো একটি বিশেষ ফরমেটে শুধু আপনার ডিভাইসে রাখা হয়, যা সরাসরি পড়া যায় না। এমনকি গোপন তথ্য যেমন পাসওয়ার্ড বা ক্রেডিট কার্ডের তথ্য কখনো আপনার ডিভাইসেও সংরক্ষণ করা হয় না। সামাজিক যোগাযোগ মাধ্যমে কেউ এ ব্যাপারে সন্দেহ প্রকাশ করলে অনুগ্রহ করে প্রমাণ দেখাতে বলুন। সম্পূর্ণ নিরাপদ থাকতে, সবসময় BanglaType কিবোর্ড প্লে-স্টোর থেকে ইনস্টল করুন। আপনার ব্যক্তিগত তথ্যের সুরক্ষায় আমরা সর্বদা প্রতিশ্রুতিবদ্ধ। সব ডাটা অফলাইন।</string>
